{
  "version": 2,
  "builds": [
    {
      "src": "trip-vault.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/trip-vault.html"
    },
    {
      "src": "/trip-vault",
      "dest": "/trip-vault.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
